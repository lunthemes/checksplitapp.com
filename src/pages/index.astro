---
import { defaultLocale, supportedLanguages } from "../i18n/config";
import { localePath } from "../i18n/paths";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <!-- Google tag (gtag.js) — same as Layout.astro -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-86G5SPYDK6"
      is:inline
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', 'G-86G5SPYDK6');
    </script>
    <meta name="robots" content="noindex" />
    <title>Redirecting…</title>
  </head>
  <body>
    <script
      is:inline
      define:vars={{ supportedLanguages, defaultLocale, defaultLocalePath: localePath(defaultLocale) }}
    >
      (function () {
        const supported = new Set(supportedLanguages);
        const fallback = supported.has("en") ? "en" : defaultLocale;
        const basePath = defaultLocalePath;
        const toLocaleHome = function (locale) {
          return basePath.replace(
            new RegExp("/" + defaultLocale + "(?:/|$)"),
            "/" + locale + "/",
          );
        };

        // Optional manual override via ?lang=xx (persisted)
        const url = new URL(window.location.href);
        const qLang = url.searchParams.get("lang");
        if (qLang && supported.has(qLang)) {
          try {
            localStorage.setItem("preferredLang", qLang);
          } catch {}
          window.location.replace(toLocaleHome(qLang));
          return;
        }

        // Saved preference wins
        try {
          const saved = localStorage.getItem("preferredLang");
          if (saved && supported.has(saved)) {
            window.location.replace(toLocaleHome(saved));
            return;
          }
        } catch {}

        const candidates = []
          .concat(navigator.languages || [])
          .concat([navigator.language])
          .filter(Boolean);

        function pickLang(tag) {
          const lower = String(tag).toLowerCase();
          const primary = lower.split("-")[0];
          if (supported.has(primary)) return primary;
          // Common special-cases
          if (primary === "uk" && supported.has("ru")) return "ru";
          return null;
        }

        let best = null;
        for (const tag of candidates) {
          const picked = pickLang(tag);
          if (picked) {
            best = picked;
            break;
          }
        }

        const target = best || fallback;
        window.location.replace(toLocaleHome(target));
      })();
    </script>
  </body>
</html>