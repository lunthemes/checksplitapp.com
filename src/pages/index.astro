---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import FeatureBar from "../components/FeatureBar.astro";
import HowItWorks from "../components/HowItWorks.astro";
import UseCases from "../components/UseCases.astro";
import CallToAction from "../components/CallToAction.astro";
import FAQ from "../components/FAQ.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="CheqSplit: Split Bills, Scan Receipts & Track Group Expenses"
  description="CheqSplit helps you scan receipts, split bills by item, track group expenses, and see who owes whom. Perfect for trips, restaurants, roommates, families, and shared shopping."
  ogDescription="Scan receipts, split bills by item, track group expenses, and instantly see who owes whom. Perfect for trips, restaurants, roommates, and families."
  twitterDescription="The easy way to split receipts and shared expenses without awkward math."
  canonicalUrl="https://cheqsplitapp.com/"
  ogImageUrl="https://cheqsplitapp.com/og-image.png"
  preloadHeroImage="/backgrounds/home-hero.png"
>
  <Header />
  <main>
    <Hero />
    <FeatureBar />
    <HowItWorks />
    <UseCases />
    <CallToAction />
    <FAQ />
  </main>
  <Footer />
</Layout>
