---
import "../styles/global.scss";
import { siteUrl } from "../data/structured-data";

interface Props {
  title: string;
  description?: string;
  /** Open Graph & social card description (can differ from meta description) */
  ogDescription?: string;
  /** Twitter card description */
  twitterDescription?: string;
  /** Absolute canonical URL, usually with trailing slash */
  canonicalUrl?: string;
  /** Open Graph & Twitter image (absolute URL) */
  ogImageUrl?: string;
  /** LCP/hero: background image path to preload (e.g. /backgrounds/home-hero.png) */
  preloadHeroImage?: string;
  /** BCP 47 language code for <html lang> */
  lang?: string;
  /** `href` + `hreflang` for alternate language versions of this page */
  alternatePages?: { href: string; hreflang: string }[];
  /** Main locale URL for hreflang="x-default" (e.g. English homepage) */
  xDefaultUrl?: string;
  /** JSON-LD string for SoftwareApplication (locale-specific description) */
  softwareJsonLd: string;
  /** JSON-LD string for FAQPage (locale-matched) */
  faqJsonLd: string;
}

const {
  title,
  description = "CheqSplit helps you scan receipts, split bills by item, track group expenses, and see who owes whom. Perfect for trips, restaurants, roommates, families, and shared shopping.",
  ogDescription = "Scan receipts, split bills by item, track group expenses, and instantly see who owes whom. Perfect for trips, restaurants, roommates, and families.",
  twitterDescription = "The easy way to split receipts and shared expenses without awkward math.",
  canonicalUrl = siteUrl + "/",
  ogImageUrl = "https://cheqsplitapp.com/og-image.png",
  preloadHeroImage,
  lang = "en",
  alternatePages = [],
  xDefaultUrl,
  softwareJsonLd,
  faqJsonLd,
} = Astro.props;

const fullOgImage = ogImageUrl.startsWith("http") ? ogImageUrl : new URL(ogImageUrl, siteUrl + "/").href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {alternatePages.map((a) => (
      <link rel="alternate" href={a.href} hreflang={a.hreflang} />
    ))}
    {xDefaultUrl && <link rel="alternate" href={xDefaultUrl} hreflang="x-default" />}
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={twitterDescription} />
    <meta name="twitter:image" content={fullOgImage} />

    {preloadHeroImage && (
      <link
        rel="preload"
        as="image"
        href={preloadHeroImage}
        fetchpriority="high"
      />
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-86G5SPYDK6"
    />
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-86G5SPYDK6");
    </script>
    <script is:inline type="application/ld+json" set:html={softwareJsonLd} />
    <script is:inline type="application/ld+json" set:html={faqJsonLd} />
  </head>
  <body class="min-h-dvh font-sans antialiased text-slate-900 bg-white">
    <slot />
    <script is:inline>
      (function () {
        document.addEventListener("click", function (e) {
          const el = e.target;
          if (!el || !("closest" in el)) return;
          const link = el.closest("a[data-ga-event]");
          if (!link || !window.gtag) return;
          const name = link.getAttribute("data-ga-event");
          if (name) window.gtag("event", name);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  html {
    font-family: "Inter", system-ui, sans-serif;
  }
  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }
</style>
