---
interface Props {
  title: string;
  desc: string;
  iconSrc: string;
  iconAlt: string;
  ring: string;
}

const { title, desc, iconSrc, iconAlt, ring } = Astro.props;
---

<article
  class="rounded-2xl border border-slate-100 bg-white p-5 shadow-sm"
>
  <div
    class:list={["mb-3 flex h-12 w-12 items-center justify-center rounded-xl ring-1", ring]}
  >
    <img
      src={iconSrc}
      alt={iconAlt}
      class="h-8 w-8 object-contain"
      width="32"
      height="32"
      loading="lazy"
    />
  </div>
  <h3 class="font-semibold text-slate-900">{title}</h3>
  <p class="mt-1 text-sm text-slate-600">{desc}</p>
</article>
