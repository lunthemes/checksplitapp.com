---
import StoreBadges from "./StoreBadges.astro";
import { ctaPhoneScreen } from "../data/screens";
---

<section
  id="download"
  class="scroll-mt-20 px-4 py-5 md:px-6"
  aria-label="Download CheqSplit"
>
  <div
    class="mx-auto w-full max-w-6xl overflow-hidden rounded-3xl shadow-[0_20px_50px_-12px_rgba(37,99,235,0.4)] ring-1 ring-white/20"
  >
    <div class="relative min-h-0">
      <img
        src="/backgrounds/cta-gradient.png"
        alt=""
        class="pointer-events-none absolute inset-0 h-full w-full rounded-3xl object-cover object-center"
        width="1920"
        height="800"
        loading="lazy"
        aria-hidden="true"
      />
      <div
        class="relative z-10 p-5 sm:p-6 md:px-9 md:py-8 lg:px-10 lg:py-9"
      >
        <div
          class="pointer-events-none absolute left-[38%] top-1/2 z-[5] hidden -translate-x-1/2 -translate-y-1/2 md:left-[44%] md:block lg:left-[46%]"
          aria-hidden="true"
        >
          <svg
            class="h-5 w-5 text-white/75 drop-shadow-sm sm:h-6 sm:w-6"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M1.9 20.1L22.8 12 1.9 3.9v5.1l13.1 2.1L1.9 15.1v4.8z"
            />
          </svg>
        </div>
        <div
          class="relative z-20 w-full text-center md:max-w-[50%] md:pr-4 md:text-left"
        >
          <h2
            class="text-balance text-2xl font-bold leading-tight tracking-tight text-white [text-shadow:0_1px_3px_rgba(0,0,0,0.2)] sm:text-3xl md:text-[1.9rem] lg:text-[2.1rem] lg:leading-tight"
          >
            Ready to split smarter?
          </h2>
          <p
            class="mx-auto mt-3 max-w-md text-pretty text-base text-white md:mx-0 md:mt-3.5 md:text-lg"
          >
            Join thousands of groups who split expenses without the stress.
          </p>
          <div class="mt-5 flex flex-wrap justify-center gap-2 sm:mt-6 md:justify-start">
            <StoreBadges variant="cta" />
          </div>
        </div>
        <div
          class="mt-3 flex justify-center sm:mt-4 md:mt-0 md:hidden"
        >
          <div
            class="relative -mt-[55px] h-40 w-full max-w-[12.5rem] origin-bottom overflow-hidden [transform:rotate(-5deg)] sm:h-44"
          >
            <img
              src={ctaPhoneScreen}
              alt="CheqSplit pe iPhone"
              class="absolute left-0 top-0 h-[128%] w-full object-cover object-top"
              width="1122"
              height="1402"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <div
          class="pointer-events-none hidden min-h-0 md:absolute md:bottom-0 md:right-0 md:top-0 md:z-0 md:block md:w-1/2"
        >
          <div
            class="flex h-full w-full min-h-0 items-start justify-end pr-2 pt-4 sm:pr-3 sm:pt-5 md:pr-5 md:pt-6 lg:pr-7 lg:pt-7"
            aria-hidden="true"
          >
            <div
              class="relative -mt-[55px] w-full max-w-[min(24rem,46vw)] origin-bottom-right -translate-x-1 -rotate-[5deg] overflow-hidden [height:min(28rem,50dvh)] sm:[height:min(30rem,48dvh)] md:-translate-x-2 lg:[height:min(32rem,45dvh)]"
            >
              <img
                src={ctaPhoneScreen}
                alt=""
                class="absolute left-0 top-0 h-[122%] w-full object-cover object-top sm:h-[125%]"
                width="1122"
                height="1402"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
