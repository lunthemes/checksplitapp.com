---
import StoreBadges from "./StoreBadges.astro";
import { ctaPhoneScreen } from "../data/screens";
import type { Dictionary } from "../i18n/types";

export interface Props {
  t: Dictionary;
}

const { t } = Astro.props;
---

<section
  id="download"
  class="scroll-mt-20 px-4 py-5 md:px-6"
  aria-label={t.cta.sectionAria}
>
  <div
    class="mx-auto w-full max-w-6xl overflow-hidden rounded-3xl shadow-[0_20px_50px_-12px_rgba(37,99,235,0.4)] ring-1 ring-white/20"
  >
    <div class="relative min-h-0 overflow-hidden rounded-3xl">
      <img
        src="/backgrounds/cta-gradient.png"
        alt=""
        class="pointer-events-none absolute inset-0 h-full w-full rounded-3xl object-cover object-center"
        width="1920"
        height="800"
        loading="lazy"
        aria-hidden="true"
      />
      <div
        class="relative z-10 px-5 pt-4 max-md:pb-0 sm:px-6 sm:pt-5 sm:pb-1 md:px-9 md:py-8 lg:px-10 lg:py-9"
      >
        <div
          class="relative z-20 w-full text-center md:max-w-[50%] md:pr-4 md:text-left"
        >
          <h2
            class="typography typ-h2 text-balance text-white [text-shadow:0_1px_3px_rgba(0,0,0,0.2)] md:[font-size:33.6px]"
          >
            {t.cta.title}
          </h2>
          <p
            class="mx-auto mt-3 max-w-md text-pretty text-base text-white md:mx-0 md:mt-3.5 md:text-lg"
          >
            {t.cta.body}
          </p>
          <div class="mt-5 flex flex-wrap justify-center gap-2 sm:mt-6 md:justify-start">
            <StoreBadges
              variant="cta"
              appStoreAlt={t.cta.badgeAlts.appStore}
              playAlt={t.cta.badgeAlts.play}
              playSoon={t.cta.playSoon}
              playDisabledHint={t.cta.playDisabledHint}
              groupAria={t.cta.groupAria}
            />
          </div>
        </div>
        <div
          class="mt-3.5 flex w-full justify-center sm:mt-4 md:mt-0 md:hidden max-md:-translate-y-0.5"
        >
          <div
            class="relative h-44 w-full max-w-[240px] overflow-hidden sm:h-48 sm:max-w-[264px]"
          >
            <img
              src={ctaPhoneScreen}
              alt={t.cta.imgAlt}
              class="absolute left-0 top-0 h-[128%] w-full object-cover object-top [transform:translateZ(0)]"
              width="1122"
              height="1402"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <div
          class="pointer-events-none hidden min-h-0 md:absolute md:bottom-0 md:right-0 md:top-0 md:z-0 md:block md:w-1/2"
        >
          <div
            class="flex h-full w-full min-h-0 items-start justify-end pr-2 pt-4 sm:pr-3 sm:pt-5 md:pr-5 md:pt-6 lg:pr-7 lg:pt-7"
            aria-hidden="true"
          >
            <div
              class="relative -mt-[85px] mr-[50px] w-full min-w-0 max-w-[min(448px,52vw)] -translate-x-1 -translate-y-0.5 overflow-hidden [height:min(512px,55dvh)] sm:[height:min(544px,52dvh)] md:-translate-x-2 lg:[height:min(576px,48dvh)]"
            >
              <img
                src={ctaPhoneScreen}
                alt=""
                class="absolute max-xl:inset-0 max-xl:h-full max-xl:w-full max-xl:object-contain max-xl:object-bottom xl:left-0 xl:top-0 xl:h-[120%] xl:w-full xl:object-cover xl:object-top [transform:translateZ(0)]"
                width="1122"
                height="1402"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
