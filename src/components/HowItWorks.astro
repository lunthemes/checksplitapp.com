---
import SectionHeader from "./SectionHeader.astro";
import StepRow from "./StepRow.astro";
import { howSteps } from "../data/landing";
---

<section id="how" class="pt-20 md:pt-28" aria-label="How it works">
  <div class="mx-auto max-w-6xl px-4 pb-4 md:px-6">
    <SectionHeader
      title="How it works"
      subtitle="Five clear steps from trip to a clean report everyone can trust."
    />
  </div>
  {howSteps.map((s, i) => {
    const reverse = i % 2 === 1;
    return (
      <div class:list={["w-full", s.theme.section]}>
        <div
          class:list={[
            "mx-auto max-w-6xl px-4 sm:px-5 md:px-6",
            "pt-12 sm:pt-14 md:pt-16 lg:pt-20",
            i === howSteps.length - 1
              ? "pb-16 md:pb-20"
              : "pb-0",
          ]}
        >
          <StepRow
            step={s.step}
            label={s.label}
            body={s.body}
            image={s.image}
            items={[...s.items]}
            theme={s.theme}
            reverse={reverse}
          />
        </div>
      </div>
    );
  })}
</section>
