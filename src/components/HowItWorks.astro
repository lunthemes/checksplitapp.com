---
import SectionHeader from "./SectionHeader.astro";
import StepRow from "./StepRow.astro";
import type { Dictionary } from "../i18n/types";

type HowStep = {
  step: string;
  label: string;
  body: string;
  image: { src: string; alt: string };
  items: string[];
  theme: {
    section: string;
    pill: string;
    check: string;
  };
};

export interface Props {
  t: Dictionary;
  howSteps: HowStep[];
}

const { t, howSteps } = Astro.props;
---

<section
  id="how"
  class="pt-20 md:pt-28"
  aria-label={t.a11y.howSection}
>
  <div class="mx-auto max-w-6xl px-4 pb-4 md:px-6">
    <SectionHeader title={t.how.title} subtitle={t.how.subtitle} />
  </div>
  {howSteps.map((s, i) => {
    const reverse = i % 2 === 1;
    return (
      <div class:list={["w-full", s.theme.section]}>
        <div
          class:list={[
            "mx-auto max-w-6xl px-4 sm:px-5 md:px-6",
            "pt-12 sm:pt-14 md:pt-16 lg:pt-20",
            i === howSteps.length - 1
              ? "pb-16 md:pb-20"
              : "pb-0",
          ]}
        >
          <StepRow
            step={s.step}
            stepPill={t.how.stepPill(s.step)}
            label={s.label}
            body={s.body}
            image={s.image}
            items={s.items}
            theme={s.theme}
            reverse={reverse}
          />
        </div>
      </div>
    );
  })}
</section>
