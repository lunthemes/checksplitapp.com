---
import SectionHeader from "./SectionHeader.astro";
import StoreBadges from "./StoreBadges.astro";
import { heroPhoneScreens } from "../data/screens";
import type { Dictionary } from "../i18n/types";

export interface Props {
  t: Dictionary;
}

const { t } = Astro.props;

const HERO_BG = "/backgrounds/home-hero.png";

const heroPhones = [
  {
    src: heroPhoneScreens[0],
    alt: t.hero.alts[0],
    wrap: [
      "relative z-10 w-[25%] min-w-[72px] max-w-[130px] md:w-[26%] md:max-w-[200px] lg:max-w-[230px]",
      "[transform:rotateY(19deg)]",
      "max-sm:[transform:rotateY(12deg)]",
      "-mr-1 md:-mr-3.5 lg:-mr-4",
    ],
  },
  {
    src: heroPhoneScreens[1],
    alt: t.hero.alts[1],
    wrap: [
      "relative z-30 -mx-2.5 w-[28%] min-w-[80px] max-w-[145px] scale-[1.04] md:-mx-5 md:max-w-[225px] md:scale-[1.08] lg:-mx-6 lg:max-w-[255px] lg:scale-[1.1]",
    ],
  },
  {
    src: heroPhoneScreens[2],
    alt: t.hero.alts[2],
    wrap: [
      "relative z-10 w-[25%] min-w-[72px] max-w-[130px] md:w-[26%] md:max-w-[200px] lg:max-w-[230px]",
      "[transform:rotateY(-19deg)]",
      "max-sm:[transform:rotateY(-12deg)]",
      "-ml-1 md:-ml-3.5 lg:-ml-4",
    ],
  },
] as const;
---

<section class="hero">
  <div
    class="hero__bg"
    aria-hidden="true"
  >
    <img
      src={HERO_BG}
      alt=""
      width="1920"
      height="1080"
      fetchpriority="high"
      loading="eager"
      decoding="async"
    />
  </div>
  <div class="hero__overlay" aria-hidden="true" />
  <div
    class="hero__grid"
  >
  <div>
    <SectionHeader
      as="h1"
      align="left"
      title={t.hero.title}
    />
    <p class="mt-4 text-lg text-slate-600">
      {t.hero.body}
    </p>
    <div class="mt-8">
      <StoreBadges
        variant="hero"
        appStoreAlt={t.cta.badgeAlts.appStore}
        playAlt={t.cta.badgeAlts.play}
        playSoon={t.cta.playSoon}
        playDisabledHint={t.cta.playDisabledHint}
        groupAria={t.cta.groupAria}
      />
    </div>
  </div>
  <div class="hero__visual">
    <div
      class="hero__phones-wrap"
    >
      <div
        class="hero__phones"
      >
        {heroPhones.map((h) => (
          <div class:list={["hero__phone", ...h.wrap]}>
            <img
              src={h.src}
              alt={h.alt}
              width="360"
              height="780"
              loading="eager"
              decoding="async"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
  </div>
</section>
