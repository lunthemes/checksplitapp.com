---
import Logo from "./Logo.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import type { Dictionary } from "../i18n/types";
import { localePath } from "../i18n/paths";
import type { SupportedLanguage } from "../i18n/config";

export interface Props {
  lang: SupportedLanguage;
  t: Dictionary;
}

const { lang, t } = Astro.props;
---

<header
  class="sticky top-0 z-50 border-b border-slate-100 bg-white/80 backdrop-blur"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 md:px-6"
  >
    <Logo
      variant="header"
      homeHref={localePath(lang)}
      homeAriaLabel={t.a11y.logoHome}
    />
    <nav
      class="hidden items-center gap-8 text-sm font-medium text-slate-600 lg:flex"
      aria-label={t.a11y.primaryNav}
    >
      <a href="#features" class="hover:text-brand-600">{t.nav.features}</a>
      <a href="#how" class="hover:text-brand-600">{t.nav.how}</a>
      <a href="#use-cases" class="hover:text-brand-600">{t.nav.useCases}</a>
      <a href="#faq" class="hover:text-brand-600">{t.nav.faq}</a>
    </nav>
    <div class="flex min-w-0 shrink-0 items-center gap-2 sm:gap-2.5">
      <LanguageSwitcher current={lang} />
      <a
        href="#download"
        class="hidden whitespace-nowrap rounded-lg bg-brand-500 px-3 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-600 sm:px-4 lg:inline-flex"
        data-ga-event="click_download_app"
      >
        {t.header.download}
      </a>
      <details class="group relative z-[55] -mr-0.5 list-none lg:hidden">
        <summary
          class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-lg border border-slate-200/90 bg-white text-slate-800 shadow-sm [details[open]>&]:ring-1 [details[open]>&]:ring-slate-300 [details[open]>&]:ring-offset-0 focus:outline-none focus:ring-1 focus:ring-slate-300 focus:ring-offset-0 [&::-webkit-details-marker]:hidden"
          aria-label={t.a11y.openMenu}
        >
          <svg
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 20 20"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M3 5a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1Zm0 5a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1Zm0 5a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1Z"
              clip-rule="evenodd"></path>
          </svg>
        </summary>
        <div
          class="absolute right-0 top-full z-[55] mt-2 w-[min(18.5rem,calc(100vw-1.5rem))] max-w-sm rounded-xl border border-slate-200/90 bg-white py-1 shadow-lg ring-1 ring-slate-900/5"
        >
          <nav
            class="flex flex-col text-sm font-medium text-slate-700"
            aria-label={t.a11y.primaryNav}
          >
            <a
              href="#features"
              class="px-4 py-3 transition hover:bg-slate-50 hover:text-brand-600"
              >{t.nav.features}</a
            >
            <a
              href="#how"
              class="px-4 py-3 transition hover:bg-slate-50 hover:text-brand-600"
              >{t.nav.how}</a
            >
            <a
              href="#use-cases"
              class="px-4 py-3 transition hover:bg-slate-50 hover:text-brand-600"
              >{t.nav.useCases}</a
            >
            <a
              href="#faq"
              class="px-4 py-3 transition hover:bg-slate-50 hover:text-brand-600"
              >{t.nav.faq}</a
            >
          </nav>
          <div class="border-t border-slate-100 p-2">
            <a
              href="#download"
              class="block w-full rounded-lg bg-brand-500 px-3 py-2.5 text-center text-sm font-semibold text-white shadow-sm transition hover:bg-brand-600"
              data-ga-event="click_download_app"
            >
              {t.header.download}
            </a>
          </div>
        </div>
      </details>
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener("click", (e) => {
    const header = document.querySelector("header");
    if (!header) return;
    const t = e.target;
    if (!(t instanceof Node)) return;
    header.querySelectorAll("details[open]").forEach((details) => {
      if (!details.contains(t)) {
        details.removeAttribute("open");
      }
    });
  });
</script>
