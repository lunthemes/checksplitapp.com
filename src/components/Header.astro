---
import Logo from "./Logo.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import type { Dictionary } from "../i18n/types";
import { localePath } from "../i18n/paths";
import type { SupportedLanguage } from "../i18n/config";

export interface Props {
  lang: SupportedLanguage;
  t: Dictionary;
  /** When set (e.g. `/en/`), nav targets homepage anchors as `${sectionBase}#features`. */
  sectionBase?: string;
}

const { lang, t, sectionBase = "" } = Astro.props;
const hb = sectionBase;
---

<header
  class="site-header"
>
  <div
    class="site-header__inner"
  >
    <Logo
      variant="header"
      homeHref={localePath(lang)}
      homeAriaLabel={t.a11y.logoHome}
    />
    <nav
      class="site-header__nav"
      aria-label={t.a11y.primaryNav}
    >
      <a href={`${hb}#features`} class="hover:text-brand-600">{t.nav.features}</a>
      <a href={`${hb}#how`} class="hover:text-brand-600">{t.nav.how}</a>
      <a href={`${hb}#use-cases`} class="hover:text-brand-600">{t.nav.useCases}</a>
      <a href={`${hb}#faq`} class="hover:text-brand-600">{t.nav.faq}</a>
    </nav>
    <div class="site-header__actions">
      <LanguageSwitcher current={lang} />
      <a
        href={`${hb}#download`}
        class="site-header__cta"
        data-ga-event="click_download_app"
      >
        {t.header.download}
      </a>
      <details class="site-header__menu">
        <summary aria-label={t.a11y.openMenu}>
          <svg
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 20 20"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M3 5a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1Zm0 5a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1Zm0 5a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1Z"
              clip-rule="evenodd"></path>
          </svg>
        </summary>
        <div
          class="site-header__menu-panel"
        >
          <nav
            class="site-header__menu-links"
            aria-label={t.a11y.primaryNav}
          >
            <a
              href={`${hb}#features`}
              class=""
              >{t.nav.features}</a
            >
            <a
              href={`${hb}#how`}
              class=""
              >{t.nav.how}</a
            >
            <a
              href={`${hb}#use-cases`}
              class=""
              >{t.nav.useCases}</a
            >
            <a
              href={`${hb}#faq`}
              class=""
              >{t.nav.faq}</a
            >
          </nav>
          <div class="site-header__menu-footer">
            <a
              href={`${hb}#download`}
              class="site-header__menu-cta"
              data-ga-event="click_download_app"
            >
              {t.header.download}
            </a>
          </div>
        </div>
      </details>
    </div>
  </div>
</header>

<script is:inline>
  const header = document.querySelector(".site-header");
  if (header) {
    const onScroll = () => {
      header.classList.toggle("site-header--scrolled", window.scrollY > 8);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  document.addEventListener("click", (e) => {
    const header = document.querySelector(".site-header");
    if (!header) return;
    const t = e.target;
    if (!(t instanceof Node)) return;
    header.querySelectorAll("details[open]").forEach((details) => {
      if (!details.contains(t)) {
        details.removeAttribute("open");
      }
    });
  });
</script>
