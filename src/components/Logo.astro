---
import { site } from "../data/landing";

export interface Props {
  /** Header: icon + text mai proeminent. Footer: puțin mai discret. */
  variant?: "header" | "footer";
  /** Home URL including locale, e.g. /en/ */
  homeHref?: string;
  /** Accessible name for the home link */
  homeAriaLabel?: string;
}

const { variant = "header", homeHref = "/", homeAriaLabel } = Astro.props;
const aria = homeAriaLabel ?? `${site.name} home`;
---

<a
  href={homeHref}
  class="inline-flex items-center gap-2.5"
  aria-label={aria}
>
  <img
    src={site.logoIcon}
    alt=""
    width="40"
    height="40"
    class:list={[
      "shrink-0 object-contain",
      variant === "header" && "h-9 w-9 sm:h-10 sm:w-10",
      variant === "footer" && "h-8 w-8",
    ]}
    loading={variant === "header" ? "eager" : "lazy"}
    decoding="async"
  />
  <span
    class:list={[
      "text-slate-900",
      variant === "header" &&
        "hidden text-lg font-extrabold tracking-tight sm:inline sm:text-xl",
      variant === "footer" && "text-base font-extrabold tracking-tight",
    ]}
  >
    {site.name}
  </span>
</a>
