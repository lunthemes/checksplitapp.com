---
import { featureItems } from "../data/landing";
import FeatureCard from "./FeatureCard.astro";
---

<section
  id="features"
  class="border-y border-slate-100 bg-slate-50/50 py-12 md:py-16"
  aria-label="Key features"
>
  <div
    class="mx-auto grid max-w-6xl grid-cols-1 gap-8 px-4 sm:grid-cols-2 md:grid-cols-4 md:px-6"
  >
    {featureItems.map((f) => (
      <FeatureCard
        title={f.title}
        desc={f.desc}
        iconSrc={f.icon}
        iconAlt=""
        iconBg={f.iconBg}
      />
    ))}
  </div>
</section>
