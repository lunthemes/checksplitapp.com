---
import FeatureCard from "./FeatureCard.astro";
import SectionHeader from "./SectionHeader.astro";
import type { Dictionary } from "../i18n/types";

export interface Props {
  t: Dictionary;
  items: {
    title: string;
    desc: string;
    icon: string;
    iconBg: string;
  }[];
}

const { t, items } = Astro.props;
---

<section
  id="features"
  class="border-y border-slate-100 bg-slate-50/50 py-12 md:py-16"
  aria-label={t.a11y.keyFeatures}
>
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <SectionHeader title={t.features.title} />
  </div>
  <div
    class="mx-auto mt-10 grid max-w-6xl grid-cols-1 gap-8 px-4 sm:grid-cols-2 md:mt-12 md:grid-cols-4 md:px-6"
  >
    {items.map((f) => (
      <FeatureCard
        title={f.title}
        desc={f.desc}
        iconSrc={f.icon}
        iconAlt=""
        iconBg={f.iconBg}
      />
    ))}
  </div>
</section>
