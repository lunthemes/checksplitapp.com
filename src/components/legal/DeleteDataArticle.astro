---
import type { DeleteDataPage } from "../../i18n/legal/types";
import type { SupportedLanguage } from "../../i18n/config";
import { localeLegalPath } from "../../i18n/paths";

interface Props {
  c: DeleteDataPage;
  lang: SupportedLanguage;
}

const { c, lang } = Astro.props;
const tp = (slug: Parameters<typeof localeLegalPath>[1]) => localeLegalPath(lang, slug);
---

<article class="legal-doc text-slate-800" aria-labelledby="del-data-title">
  <header class="mb-10 border-b border-slate-200 pb-8">
    <h1 id="del-data-title" class="text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">{c.h1}</h1>
    <p class="mt-3 text-sm text-slate-600">
      <strong>{c.lastUpdatedPrefix}</strong>
      {c.lastUpdatedDate}
    </p>
  </header>

  <div class="space-y-10 text-base leading-relaxed">
    <p set:html={c.intro} />

    <section class="space-y-4" aria-labelledby="step1">
      <h2 id="step1" class="text-xl font-semibold text-slate-900">{c.step1Title}</h2>
      <p>{c.step1Intro}</p>
      <ul class="list-disc space-y-2 pl-6">
        {
          c.step1Bullets.map((b) => (
            <li>
              <strong>{b.label}:</strong> {b.text}
            </li>
          ))
        }
      </ul>
      <p>{c.step1Note}</p>
    </section>

    <section class="space-y-4" aria-labelledby="step2">
      <h2 id="step2" class="text-xl font-semibold text-slate-900">{c.step2Title}</h2>
      <p>{c.step2Intro}</p>
      <ol class="list-decimal space-y-3 pl-6">
        <li set:html={c.step2Steps[0]} />
        <li set:html={c.step2Steps[1]} />
        <li set:html={c.step2Steps[2]} />
      </ol>
      <p>{c.step2Note}</p>
    </section>

    <section class="space-y-4" aria-labelledby="del-vs-keep">
      <h2 id="del-vs-keep" class="text-xl font-semibold text-slate-900">{c.vsTitle}</h2>
      <ul class="list-disc space-y-3 pl-6">
        {
          c.vsBullets.map((b) => (
            <li>
              <strong>{b.label}</strong> {b.text}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="space-y-4" aria-labelledby="timing2">
      <h2 id="timing2" class="text-xl font-semibold text-slate-900">{c.timingTitle}</h2>
      <p set:html={c.timingBody} />
    </section>

    <nav class="border-t border-slate-200 pt-8 text-sm text-slate-600" aria-label="Related legal pages">
      <p>
        {c.accountInsteadLead}{" "}
        <a class="font-medium text-brand-600 hover:text-brand-700" href={tp("delete-account")}>{c.accountInsteadLinkText}</a
        >{c.accountInsteadTail}
      </p>
      <p class="mt-3">
        {c.privacyLead}{" "}
        <a class="font-medium text-brand-600 hover:text-brand-700" href={tp("privacy-policy")}>{c.privacyLinkText}</a
        >{c.privacyTail}
      </p>
    </nav>
  </div>
</article>
