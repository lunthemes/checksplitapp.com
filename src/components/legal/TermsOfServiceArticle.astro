---
import type { TermsPage } from "../../i18n/legal/types";
import type { SupportedLanguage } from "../../i18n/config";
import { localeLegalPath } from "../../i18n/paths";

interface Props {
  c: TermsPage;
  lang: SupportedLanguage;
}

const { c, lang } = Astro.props;
const tp = (slug: Parameters<typeof localeLegalPath>[1]) => localeLegalPath(lang, slug);
---

<article class="legal-doc text-slate-800" aria-labelledby="tos-title">
  <header class="mb-10 border-b border-slate-200 pb-8">
    <h1 id="tos-title" class="text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">{c.h1}</h1>
    <p class="mt-3 text-sm text-slate-600">
      <strong>{c.lastUpdatedPrefix}</strong>
      {c.lastUpdatedDate}
    </p>
  </header>

  <div class="space-y-10 text-base leading-relaxed">
    <p>{c.welcome}</p>

    <section class="space-y-4" aria-labelledby="tos1">
      <h2 id="tos1" class="text-xl font-semibold text-slate-900">{c.s1Title}</h2>
      <p>
        {c.s1BeforePrivacyLink}
        <a class="font-medium text-brand-600 underline hover:text-brand-700" href={tp("privacy-policy")}
          >{c.s1PrivacyLinkText}</a
        >{c.s1AfterPrivacyLink}
      </p>
    </section>

    <section class="space-y-4" aria-labelledby="tos2">
      <h2 id="tos2" class="text-xl font-semibold text-slate-900">{c.s2Title}</h2>
      <p>{c.s2Intro}</p>
      <ul class="list-disc space-y-2 pl-6">
        {c.s2List.map((line) => <li>{line}</li>)}
      </ul>

      <aside
        class="my-6 rounded-lg border border-amber-300 bg-amber-50 p-4 text-slate-900 shadow-sm"
        aria-label={c.importantTitle}
      >
        <p class="font-semibold">{c.importantTitle}</p>
        <p class="mt-2">{c.importantBody}</p>
      </aside>
    </section>

    <section class="space-y-4" aria-labelledby="tos3">
      <h2 id="tos3" class="text-xl font-semibold text-slate-900">{c.s3Title}</h2>
      <p>{c.s3Intro}</p>
      <ul class="list-disc space-y-2 pl-6">
        {c.s3List.map((line) => <li>{line}</li>)}
      </ul>
    </section>

    <section class="space-y-4" aria-labelledby="tos4">
      <h2 id="tos4" class="text-xl font-semibold text-slate-900">{c.s4Title}</h2>
      <p set:html={c.s4Intro} />
      <ul class="list-disc space-y-2 pl-6">
        {c.s4List.map((line) => <li>{line}</li>)}
      </ul>
      <p class="mt-4">
        {c.s4SubscriptionsLead}
        <a class="font-medium text-brand-600 underline hover:text-brand-700" href={tp("privacy-policy")}
          >{c.s4SubscriptionsPrivacyLinkText}</a
        >{c.s4SubscriptionsTail}
      </p>
    </section>

    <section class="space-y-4" aria-labelledby="tos5">
      <h2 id="tos5" class="text-xl font-semibold text-slate-900">{c.s5Title}</h2>
      <p>{c.s5Intro}</p>
      <ul class="list-disc space-y-2 pl-6">
        {c.s5List.map((line) => <li>{line}</li>)}
      </ul>
    </section>

    <section class="space-y-4" aria-labelledby="tos6">
      <h2 id="tos6" class="text-xl font-semibold text-slate-900">{c.s6Title}</h2>
      <p>{c.s6Body}</p>
    </section>

    <section class="space-y-4" aria-labelledby="tos7">
      <h2 id="tos7" class="text-xl font-semibold text-slate-900">{c.s7Title}</h2>
      <p>{c.s7Intro}</p>
      <ul class="list-disc space-y-2 pl-6">
        {c.s7List.map((line) => <li>{line}</li>)}
      </ul>
    </section>

    <section class="space-y-4" aria-labelledby="tos8">
      <h2 id="tos8" class="text-xl font-semibold text-slate-900">{c.s8Title}</h2>
      <p>{c.s8Body}</p>
    </section>

    <section class="space-y-4" aria-labelledby="tos9">
      <h2 id="tos9" class="text-xl font-semibold text-slate-900">{c.s9Title}</h2>
      <p>{c.s9Body}</p>
    </section>

    <section class="space-y-4" aria-labelledby="tos10">
      <h2 id="tos10" class="text-xl font-semibold text-slate-900">{c.s10Title}</h2>
      <p>{c.s10Intro}</p>
      <ul class="list-disc space-y-2 pl-6">
        {c.s10List.map((line) => <li>{line}</li>)}
      </ul>
    </section>

    <section class="space-y-4" aria-labelledby="tos11">
      <h2 id="tos11" class="text-xl font-semibold text-slate-900">{c.s11Title}</h2>
      <p>{c.s11Body}</p>
    </section>

    <section class="space-y-4" aria-labelledby="tos12">
      <h2 id="tos12" class="text-xl font-semibold text-slate-900">{c.s12Title}</h2>
      <p>{c.s12Intro}</p>
      <ul class="list-disc space-y-2 pl-6">
        <li>
          <strong>{c.emailLabel}</strong>{" "}
          <a class="font-medium text-brand-600 underline hover:text-brand-700" href="mailto:lungusterus@gmail.com"
            >lungusterus@gmail.com</a
          >
        </li>
        <li>
          <strong>{c.developerLabel}</strong> {c.developerName}
        </li>
      </ul>
    </section>

    <nav class="border-t border-slate-200 pt-8 text-sm text-slate-600" aria-label="Related legal pages">
      <p>
        {c.relatedNavLabel}{" "}
        <a class="font-medium text-brand-600 hover:text-brand-700" href={tp("privacy-policy")}>{c.relatedPrivacy}</a>,{" "}
        <a class="font-medium text-brand-600 hover:text-brand-700" href={tp("delete-account")}>{c.relatedDeleteAccount}</a>,{" "}
        <a class="font-medium text-brand-600 hover:text-brand-700" href={tp("delete-data")}>{c.relatedDeleteData}</a>.
      </p>
    </nav>
  </div>
</article>
