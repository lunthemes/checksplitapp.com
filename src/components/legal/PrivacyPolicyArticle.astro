---
import type { PrivacyPage } from "../../i18n/legal/types";
import type { SupportedLanguage } from "../../i18n/config";
import { localeLegalPath } from "../../i18n/paths";

interface Props {
  c: PrivacyPage;
  lang: SupportedLanguage;
}

const { c, lang } = Astro.props;
const tp = (slug: Parameters<typeof localeLegalPath>[1]) => localeLegalPath(lang, slug);
---

<article class="legal-doc text-slate-800" aria-labelledby="legal-title">
  <header class="mb-10 border-b border-slate-200 pb-8">
    <h1 id="legal-title" class="text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
      {c.h1}
    </h1>
    <p class="mt-3 text-sm text-slate-600">
      <strong>{c.lastUpdatedPrefix}</strong>
      {c.lastUpdatedDate}
    </p>
  </header>

  <div class="space-y-10 text-base leading-relaxed">
    <p>{c.intro}</p>

    <section class="space-y-4" aria-labelledby="s1">
      <h2 id="s1" class="text-xl font-semibold text-slate-900">{c.s1Title}</h2>
      <p>{c.s1Intro}</p>
      <ul class="list-disc space-y-3 pl-6">
        {
          c.s1Bullets.map((b) => (
            <li>
              <strong>{b.label}:</strong> {b.text}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="space-y-4" aria-labelledby="s2">
      <h2 id="s2" class="text-xl font-semibold text-slate-900">{c.s2Title}</h2>
      <p>{c.s2Intro}</p>
      <ul class="list-disc space-y-2 pl-6">
        {c.s2List.map((line) => <li>{line}</li>)}
      </ul>
    </section>

    <section class="space-y-4" aria-labelledby="s3">
      <h2 id="s3" class="text-xl font-semibold text-slate-900">{c.s3Title}</h2>
      <p>{c.s3Intro}</p>
      <ul class="list-disc space-y-2 pl-6">
        {c.s3List.map((line) => <li>{line}</li>)}
      </ul>
    </section>

    <section class="space-y-4" aria-labelledby="s4">
      <h2 id="s4" class="text-xl font-semibold text-slate-900">{c.s4Title}</h2>
      <p>{c.s4Intro}</p>
      <ul class="list-disc space-y-2 pl-6">
        {c.s4List.map((line) => <li>{line}</li>)}
      </ul>
    </section>

    <section class="space-y-4" aria-labelledby="s5">
      <h2 id="s5" class="text-xl font-semibold text-slate-900">{c.s5Title}</h2>
      <p>{c.s5Body}</p>
    </section>

    <section class="space-y-4" aria-labelledby="s6">
      <h2 id="s6" class="text-xl font-semibold text-slate-900">{c.s6Title}</h2>
      <p>{c.s6Intro}</p>
      <ul class="list-disc space-y-2 pl-6">
        {c.s6List.map((line) => <li>{line}</li>)}
      </ul>
    </section>

    <section class="space-y-4" aria-labelledby="s7">
      <h2 id="s7" class="text-xl font-semibold text-slate-900">{c.s7Title}</h2>
      <p>{c.s7Body}</p>
    </section>

    <section class="space-y-4" aria-labelledby="s8">
      <h2 id="s8" class="text-xl font-semibold text-slate-900">{c.s8Title}</h2>
      <p>{c.s8Intro}</p>
      <ul class="list-disc space-y-3 pl-6">
        {
          c.s8Bullets.map((b) => (
            <li>
              <strong>{b.label}:</strong>{" "}
              <span set:html={b.text} />
            </li>
          ))
        }
      </ul>
    </section>

    <section class="space-y-4" aria-labelledby="s9">
      <h2 id="s9" class="text-xl font-semibold text-slate-900">{c.s9Title}</h2>
      <p>{c.s9Body}</p>
    </section>

    <section class="space-y-4" aria-labelledby="s10">
      <h2 id="s10" class="text-xl font-semibold text-slate-900">{c.s10Title}</h2>
      <p>{c.s10Intro}</p>
      <ul class="list-disc space-y-2 pl-6">
        <li>
          <strong>{c.emailLabel}</strong>{" "}
          <a class="font-medium text-brand-600 underline hover:text-brand-700" href="mailto:support@cheqsplitapp.com"
            >support@cheqsplitapp.com</a
          >
        </li>
        <li>
          <strong>{c.developerLabel}</strong> {c.developerName}
        </li>
      </ul>
    </section>

    <nav class="border-t border-slate-200 pt-8 text-sm text-slate-600" aria-label="Related legal pages">
      <p>
        {c.relatedNavLabel}{" "}
        <a class="font-medium text-brand-600 hover:text-brand-700" href={tp("terms-of-service")}>{c.relatedTerms}</a>,{" "}
        <a class="font-medium text-brand-600 hover:text-brand-700" href={tp("delete-account")}>{c.relatedDeleteAccount}</a>,{" "}
        <a class="font-medium text-brand-600 hover:text-brand-700" href={tp("delete-data")}>{c.relatedDeleteData}</a>.
      </p>
    </nav>
  </div>
</article>
