---
import { stats } from "../data/landing";
---

<section
  class="border-y border-slate-200 bg-slate-900 py-12 text-slate-100"
  aria-label="Stats"
>
  <div
    class="mx-auto grid max-w-6xl grid-cols-2 gap-6 px-4 sm:grid-cols-4 md:px-6"
  >
    {stats.map((s) => (
      <div class="text-center">
        <p class="text-2xl font-bold text-white md:text-3xl">{s.n}</p>
        <p class="mt-1 text-sm text-slate-400">{s.t}</p>
      </div>
    ))}
  </div>
</section>
