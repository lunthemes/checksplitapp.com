---
import { store } from "../data/landing";

export interface Props {
  /** hero: mărime standard; cta: pe fundal colorat; footer: compact */
  variant?: "hero" | "cta" | "footer";
  class?: string;
}

const { variant = "hero", class: className } = Astro.props;

const appStoreUrl = store.appStoreUrl;
const googlePlayUrl = store.googlePlayUrl;
const appSrc = store.badgeAppStore;
const playSrc = store.badgeGooglePlay;

const sizeClass =
  variant === "footer"
    ? "h-8 sm:h-9 w-auto"
    : variant === "cta"
      ? "h-11 w-auto sm:h-12"
      : "h-10 w-auto sm:h-11";

const linkClass = [
  "inline-flex shrink-0 items-center transition-opacity hover:opacity-90",
  "rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2",
  variant === "footer" && "ring-offset-slate-50",
  variant === "hero" && "ring-offset-white",
  variant === "cta" && "ring-offset-violet-800",
];
---

<div
  class:list={["flex flex-wrap items-center gap-3 sm:gap-4", className]}
  role="group"
  aria-label="Download the app"
>
  <a
    href={appStoreUrl}
    class:list={linkClass}
    rel="noopener noreferrer"
    data-ga-event="click_app_store"
  >
    <img
      src={appSrc}
      alt="Download on the App Store"
      class:list={[sizeClass]}
      width="120"
      height="40"
      loading="eager"
      decoding="async"
    />
  </a>
  <a
    href={googlePlayUrl}
    class:list={linkClass}
    rel="noopener noreferrer"
    data-ga-event="click_google_play"
  >
    <img
      src={playSrc}
      alt="Get it on Google Play"
      class:list={[sizeClass]}
      width="135"
      height="40"
      loading="eager"
      decoding="async"
    />
  </a>
</div>
