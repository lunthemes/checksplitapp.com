---
import { store } from "../data/landing";

export interface Props {
  /** hero: mărime standard; cta: pe fundal colorat; footer: compact */
  variant?: "hero" | "cta" | "footer";
  class?: string;
  appStoreAlt: string;
  playAlt: string;
  /** Etichetă scurtă lângă Google Play (ex. «Curând») */
  playSoon: string;
  playDisabledHint: string;
  groupAria: string;
}

const { variant = "hero", class: className, appStoreAlt, playAlt, playSoon, playDisabledHint, groupAria } =
  Astro.props;

const appStoreUrl = store.appStoreUrl;
const appSrc = store.badgeAppStore;
const playSrc = store.badgeGooglePlay;

const sizeClass =
  variant === "footer"
    ? "h-8 sm:h-9 w-auto"
    : variant === "cta"
      ? "h-11 w-auto sm:h-12"
      : "h-10 w-auto sm:h-11";

const linkClass = [
  "inline-flex shrink-0 items-center transition-opacity hover:opacity-90",
  "rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2",
  variant === "footer" && "ring-offset-slate-50",
  variant === "hero" && "ring-offset-white",
  variant === "cta" && "ring-offset-violet-800",
];

const playSoonPillClass =
  variant === "footer"
    ? "text-[0.7rem] sm:text-xs bg-amber-500 text-white"
    : variant === "cta"
      ? "text-xs sm:text-sm bg-amber-200 text-amber-950"
      : "text-xs sm:text-sm bg-amber-500 text-white";
---


<div
  class:list={["flex flex-wrap items-center gap-3 sm:gap-4", className]}
  role="group"
  aria-label={groupAria}
>
  <a
    href={appStoreUrl}
    class:list={linkClass}
    rel="noopener noreferrer"
    data-ga-event="click_app_store"
  >
    <img
      src={appSrc}
      alt={appStoreAlt}
      class:list={[sizeClass]}
      width="120"
      height="40"
      loading="eager"
      decoding="async"
    />
  </a>
  <div
    role="img"
    class:list={[
      "relative inline-flex shrink-0 select-none",
      "pointer-events-none cursor-not-allowed",
      "rounded-md opacity-70 [filter:grayscale(0.55)]",
    ]}
    aria-label={`${playAlt} — ${playSoon}. ${playDisabledHint}.`}
  >
    <span
      class:list={[
        "absolute z-20 max-w-[min(100%,8rem)] truncate rounded-md text-center font-semibold leading-tight shadow-md",
        variant === "footer" ? "px-1.5 py-0.5" : "px-2.5 py-1",
        variant === "footer"
          ? "-right-1 -top-1 sm:-right-1.5 sm:-top-1.5"
          : "-right-1.5 -top-1.5 sm:-right-2.5 sm:-top-2.5",
        playSoonPillClass,
      ]}
    >
      {playSoon}
    </span>
    <img
      src={playSrc}
      alt=""
      class:list={[sizeClass]}
      width="135"
      height="40"
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
  </div>
</div>
