---
import { site } from "../data/landing";
import Logo from "./Logo.astro";
import StoreBadges from "./StoreBadges.astro";
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 py-14 md:px-6">
    <div class="flex flex-col justify-between gap-8 md:flex-row">
      <div>
        <Logo variant="footer" />
        <p class="mt-2 max-w-sm text-sm text-slate-600">
          The easier way to split group expenses—fair, fast, and clear.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-8 text-sm sm:grid-cols-3">
        <div>
          <p class="font-semibold text-slate-900">Product</p>
          <ul class="mt-2 space-y-1.5 text-slate-600">
            <li>
              <a href="#features" class="hover:text-brand-600">Features</a>
            </li>
            <li>
              <a href="#how" class="hover:text-brand-600">How it works</a>
            </li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-slate-900">Company</p>
          <ul class="mt-2 space-y-1.5 text-slate-600">
            <li>
              <a href="#" class="hover:text-brand-600">About</a>
            </li>
            <li>
              <a href="#" class="hover:text-brand-600">Contact</a>
            </li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-slate-900">Legal</p>
          <ul class="mt-2 space-y-1.5 text-slate-600">
            <li>
              <a href="#" class="hover:text-brand-600">Privacy</a>
            </li>
            <li>
              <a href="#" class="hover:text-brand-600">Terms</a>
            </li>
          </ul>
        </div>
      </div>
    </div>
    <div
      class="mt-10 flex flex-col items-start justify-between gap-4 border-t border-slate-200 pt-8 text-sm text-slate-500 md:flex-row md:items-center"
    >
      <p>© {year} {site.name}. All rights reserved.</p>
      <StoreBadges variant="footer" class="max-w-full justify-end" />
    </div>
  </div>
</footer>
