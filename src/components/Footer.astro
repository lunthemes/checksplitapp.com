---
import { site } from "../data/landing";
import Logo from "./Logo.astro";
import StoreBadges from "./StoreBadges.astro";
import type { Dictionary } from "../i18n/types";
import { localeLegalPath, localePath } from "../i18n/paths";
import type { SupportedLanguage } from "../i18n/config";

export interface Props {
  t: Dictionary;
  year: number;
  lang: SupportedLanguage;
  /** Homepage section anchors as `${sectionBase}#features`; omit on locale homepage. */
  sectionBase?: string;
}

const { t, year, lang, sectionBase = "" } = Astro.props;
const hb = sectionBase;
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 py-14 md:px-6">
    <div class="flex flex-col justify-between gap-8 md:flex-row">
      <div>
        <Logo
          variant="footer"
          homeHref={localePath(lang)}
          homeAriaLabel={t.a11y.logoHome}
        />
        <p class="mt-2 max-w-sm text-sm text-slate-600">
          {t.footer.tagline}
        </p>
      </div>
      <div class="grid grid-cols-2 gap-8 text-sm sm:grid-cols-3">
        <div>
          <p class="font-semibold text-slate-900">{t.footer.product}</p>
          <ul class="mt-2 space-y-1.5 text-slate-600">
            <li>
              <a href={`${hb}#features`} class="hover:text-brand-600">{t.nav.features}</a>
            </li>
            <li>
              <a href={`${hb}#how`} class="hover:text-brand-600">{t.nav.how}</a>
            </li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-slate-900">{t.footer.company}</p>
          <ul class="mt-2 space-y-1.5 text-slate-600">
            <li>
              <a href={localeLegalPath(lang, "support")} class="hover:text-brand-600">{t.footer.about}</a>
            </li>
            <li>
              <a
                href="mailto:lungusterus@gmail.com"
                class="hover:text-brand-600">{t.footer.contact}</a
              >
            </li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-slate-900">{t.footer.legal}</p>
          <ul class="mt-2 space-y-1.5 text-slate-600">
            <li>
              <a href={localeLegalPath(lang, "privacy-policy")} class="hover:text-brand-600"
                >{t.footer.privacy}</a
              >
            </li>
            <li>
              <a href={localeLegalPath(lang, "terms-of-service")} class="hover:text-brand-600"
                >{t.footer.terms}</a
              >
            </li>
            <li>
              <a href={localeLegalPath(lang, "delete-account")} class="hover:text-brand-600"
                >{t.footer.deleteAccount}</a
              >
            </li>
            <li>
              <a href={localeLegalPath(lang, "delete-data")} class="hover:text-brand-600"
                >{t.footer.deleteData}</a
              >
            </li>
          </ul>
        </div>
      </div>
    </div>
    <div
      class="mt-10 flex flex-col items-start justify-between gap-4 border-t border-slate-200 pt-8 text-sm text-slate-500 md:flex-row md:items-center"
    >
      <p>© {year} {site.name}. {t.footer.rights}</p>
      <StoreBadges
        variant="footer"
        class="max-w-full justify-end"
        appStoreAlt={t.cta.badgeAlts.appStore}
        playAlt={t.cta.badgeAlts.play}
        playSoon={t.cta.playSoon}
        playDisabledHint={t.cta.playDisabledHint}
        groupAria={t.cta.groupAria}
      />
    </div>
  </div>
</footer>
