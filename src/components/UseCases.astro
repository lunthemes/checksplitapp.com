---
import SectionHeader from "./SectionHeader.astro";
import UseCaseCard from "./UseCaseCard.astro";
import type { Dictionary } from "../i18n/types";

export interface Props {
  t: Dictionary;
  items: { title: string; desc: string; icon: string; ring: string }[];
}

const { t, items } = Astro.props;
---

<section
  id="use-cases"
  class="border-t border-slate-100 bg-slate-50 py-20 md:py-24"
  aria-label={t.nav.useCases}
>
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <SectionHeader
      title={t.useCases.title}
    />
    <p
      class="mx-auto mt-4 max-w-3xl text-pretty text-center text-sm leading-relaxed text-slate-600 md:mt-5 md:text-base"
    >
      {t.useCases.intro}
    </p>
    <div
      class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 md:mt-10 lg:grid-cols-4"
    >
      {items.map((u) => (
        <UseCaseCard
          title={u.title}
          desc={u.desc}
          iconSrc={u.icon}
          ring={u.ring}
        />
      ))}
    </div>
  </div>
</section>
