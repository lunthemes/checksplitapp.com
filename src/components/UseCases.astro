---
import SectionHeader from "./SectionHeader.astro";
import UseCaseCard from "./UseCaseCard.astro";
import { useCases } from "../data/landing";
---

<section
  id="use-cases"
  class="border-t border-slate-100 bg-slate-50 py-20 md:py-24"
  aria-label="Use cases"
>
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <SectionHeader
      title="Perfect for any shared expense"
    />
    <div
      class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4"
    >
      {useCases.map((u) => (
        <UseCaseCard
          title={u.title}
          desc={u.desc}
          iconSrc={u.icon}
          iconAlt={`${u.title} icon`}
          ring={u.ring}
        />
      ))}
    </div>
  </div>
</section>
