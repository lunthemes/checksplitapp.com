---
import {
  supportedLanguages,
  localeDisplayNames,
  localeFlags,
  localePickerLabel,
  type SupportedLanguage,
} from "../i18n/config";
import { localePath } from "../i18n/paths";

interface Props {
  current: SupportedLanguage;
}

const { current } = Astro.props;
const label = localePickerLabel[current];
const currentFlag = localeFlags[current];
---

<div class="relative z-[60] flex min-w-0 max-w-[min(100%,15rem)] sm:max-w-none">
  <details class="group relative w-full min-w-0 sm:w-auto sm:min-w-0">
    <summary
      class="flex w-full cursor-pointer list-none items-center gap-1.5 rounded-lg border border-slate-200/90 bg-white px-2.5 py-2 text-left text-sm font-medium text-slate-800 shadow-sm [details[open]>&]:ring-1 [details[open]>&]:ring-slate-300 [details[open]>&]:ring-offset-0 focus:outline-none focus:ring-1 focus:ring-slate-300 focus:ring-offset-0 sm:px-3"
      aria-label={`${label}: ${localeDisplayNames[current]}`}
    >
      <span class="shrink-0 text-lg leading-none" aria-hidden="true"
        >{currentFlag}</span
      >
      <span class="shrink-0 leading-tight">{label}</span>
      <span
        class="ml-0.5 shrink-0 text-slate-500 transition [details[open]>&]:rotate-180"
        aria-hidden="true">▾</span
      >
    </summary>
    <ul
      class="absolute right-0 z-[70] mt-1 max-h-72 w-full min-w-[13rem] max-w-[min(100vw-2rem,20rem)] overflow-y-auto overscroll-contain rounded-lg border border-slate-200 bg-white py-1 shadow-lg sm:min-w-[15rem]"
      role="listbox"
      aria-label={label}
    >
      {supportedLanguages.map((l) => {
        const href = localePath(l);
        return (
          <li role="none">
            <a
              href={href}
              class:list={[
                "flex items-center gap-2.5 px-3 py-2.5 text-sm",
                l === current
                  ? "bg-slate-100 font-semibold text-slate-900"
                  : "text-slate-700 hover:bg-slate-50",
              ]}
              hreflang={l}
              lang={l}
              role="option"
              aria-selected={l === current ? "true" : "false"}
            >
              <span class="shrink-0 text-base leading-none" aria-hidden="true"
                >{localeFlags[l]}</span
              >
              <span class="min-w-0 flex-1 truncate"
                >{localeDisplayNames[l]}</span
              >
            </a>
          </li>
        );
      })}
    </ul>
  </details>
</div>
