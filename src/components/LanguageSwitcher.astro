---
import {
  supportedLanguages,
  localeDisplayNames,
  localeFlags,
  localePickerLabel,
  type SupportedLanguage,
} from "../i18n/config";
import { localePath } from "../i18n/paths";

interface Props {
  current: SupportedLanguage;
  /** Per-locale link target (e.g. localized split-bill page). Defaults to home `localePath`. */
  hrefForLang?: (lang: SupportedLanguage) => string;
}

const { current, hrefForLang: hrefForLangProp } = Astro.props;
const hrefForLang = hrefForLangProp ?? localePath;
const label = localePickerLabel[current];
const currentFlag = localeFlags[current];
const sortedLanguages = [...supportedLanguages].sort((a, b) =>
  localeDisplayNames[a].localeCompare(localeDisplayNames[b], "en", {
    sensitivity: "base",
  })
);
---

<div class="language-switcher">
  <details>
    <summary
      aria-label={`${label}: ${localeDisplayNames[current]}`}
    >
      <span aria-hidden="true">{currentFlag}</span>
      <span class="language-switcher__label">{label}</span>
      <span
        class="language-switcher__chevron"
        aria-hidden="true">▾</span
      >
    </summary>
    <div
      class="language-switcher__panel"
    >
      <p
        class="language-switcher__panel-title"
        aria-hidden="true"
      >
        {label}
      </p>
      <ul
        class="language-switcher__list"
        role="listbox"
        aria-label={label}
      >
        {sortedLanguages.map((l) => {
          const href = hrefForLang(l);
          return (
            <li role="none">
              <a
                href={href}
                class:list={[
                  "language-switcher__option",
                  l === current && "language-switcher__option--active",
                ]}
                hreflang={l}
                lang={l}
                role="option"
                aria-selected={l === current ? "true" : "false"}
              >
                <span class="language-switcher__flag" aria-hidden="true">
                  {localeFlags[l]}
                </span>
                <span class="language-switcher__name">{localeDisplayNames[l]}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </details>
</div>

<script is:inline>
  (function () {
    if (typeof window === "undefined") return;
    if (window.__cheqsplitLangSwitcherOutside) return;
    window.__cheqsplitLangSwitcherOutside = true;

    document.addEventListener(
      "click",
      function (event) {
        var target = event.target;
        var el =
          target instanceof Element ? target : target && target.parentElement;
        if (!(el instanceof Element)) return;

        document
          .querySelectorAll(".language-switcher details[open]")
          .forEach(function (details) {
            var root = details.closest(".language-switcher");
            if (root && !root.contains(el)) {
              details.open = false;
            }
          });
      },
      false,
    );
  })();
</script>
