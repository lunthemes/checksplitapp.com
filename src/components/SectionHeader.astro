---
export interface Props {
  title: string;
  subtitle?: string;
  as?: "h1" | "h2" | "h3";
  class?: string;
  align?: "left" | "center";
}

const { title, subtitle, as: Tag = "h2", class: className = "", align = "center" } =
  Astro.props;
---

<div
  class:list={[
    "typography",
    { "text-left": align === "left" },
    { "text-center": align === "center" },
    className,
  ]}
>
  <Tag
    class:list={[
      "typ-title-color",
      Tag === "h1" ? "typ-h1" : Tag === "h2" ? "typ-h2" : "typ-h3",
    ]}
  >
    {title}
  </Tag>
  {subtitle && (
    <p
      class:list={[
        "mt-2 text-slate-600",
        align === "center" && "mx-auto max-w-2xl",
        align === "left" && "max-w-2xl",
      ]}
    >
      {subtitle}
    </p>
  )}
</div>
