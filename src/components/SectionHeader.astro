---
export interface Props {
  title: string;
  subtitle?: string;
  as?: "h1" | "h2" | "h3";
  class?: string;
  align?: "left" | "center";
}

const { title, subtitle, as: Tag = "h2", class: className = "", align = "center" } =
  Astro.props;
---

<div class:list={[{ "text-left": align === "left" }, { "text-center": align === "center" }, className]}>
  <Tag
    class:list={[
      Tag === "h1" ? "text-4xl font-bold leading-tight tracking-tight text-slate-900 md:text-5xl" : "text-3xl font-bold text-slate-900 md:text-4xl",
    ]}
  >
    {title}
  </Tag>
  {subtitle && (
    <p
      class:list={[
        "mt-2 text-slate-600",
        align === "center" && "mx-auto max-w-2xl",
        align === "left" && "max-w-2xl",
      ]}
    >
      {subtitle}
    </p>
  )}
</div>
