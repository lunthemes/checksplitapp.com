---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<details
  class="group rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm open:shadow-md"
>
  <summary
    class="flex cursor-pointer list-none items-center justify-between gap-2 text-left font-medium text-slate-900"
  >
    {question}
    <span
      class="inline-flex shrink-0 text-slate-400 transition duration-200 group-open:rotate-180"
      aria-hidden="true"
    >
      <svg
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m6 9 6 6 6-6" />
      </svg>
    </span>
  </summary>
  <p class="mt-2 text-sm text-slate-600">{answer}</p>
</details>
